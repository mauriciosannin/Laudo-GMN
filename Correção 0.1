diff --git a/index.html b/index.html
new file mode 100644
index 0000000000000000000000000000000000000000..6d71392a3d4c2f35d6631a31bdf0ee925899153c
--- /dev/null
+++ b/index.html
@@ -0,0 +1,92 @@
+<!doctype html>
+<html lang="pt-BR">
+  <head>
+    <meta charset="UTF-8" />
+    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
+    <meta name="theme-color" content="#2563eb" />
+    <title>Laudo GMN | Diagnóstico de Prospecção</title>
+    <link rel="manifest" href="manifest.webmanifest" />
+    <link rel="stylesheet" href="styles.css" />
+  </head>
+  <body>
+    <header class="topbar">
+      <h1>Laudo GMN</h1>
+      <p>Diagnóstico para prospectar contratos de GMN, tráfego pago e posicionamento de marca.</p>
+    </header>
+
+    <main class="container">
+      <section class="card hero">
+        <h2>Análise rápida de prospect</h2>
+        <p>Preencha apenas os dados iniciais e clique em <strong>Gerar Laudo Geral</strong>.</p>
+      </section>
+
+      <section class="card">
+        <form id="auditForm" class="form-grid">
+          <label>
+            Pesquisa (empresa ou empresário + cidade/UF na mesma caixa)
+            <input id="searchBox" name="searchBox" placeholder="Ex.: Padaria Pão Quente João Silva Campinas SP" required />
+          </label>
+
+          <label>
+            Segmento / ramo da empresa
+            <input id="segment" name="segment" placeholder="Ex.: Clínica odontológica" required />
+          </label>
+
+          <label class="full">
+            Link para extração (Instagram, TikTok ou Google)
+            <input id="sourceLink" name="sourceLink" type="url" placeholder="https://www.google.com/maps/place/..." required />
+          </label>
+
+          <div class="actions full">
+            <button type="submit">Gerar Laudo Geral</button>
+            <button id="installBtn" class="secondary" type="button" hidden>Instalar no Android</button>
+          </div>
+        </form>
+      </section>
+
+      <section id="resultSection" class="card" hidden>
+        <h2>Protocolo de Laudo Geral</h2>
+        <p id="summary"></p>
+
+        <div class="kpis">
+          <article class="kpi"><h3>Score geral (0-10)</h3><p id="presenceScore">-</p></article>
+          <article class="kpi"><h3>Prioridade comercial</h3><p id="priorityLevel">-</p></article>
+          <article class="kpi"><h3>Nota do negócio (0-5)</h3><p id="businessRating">-</p></article>
+          <article class="kpi"><h3>Média TOP 10</h3><p id="topRatingAvg">-</p></article>
+        </div>
+
+        <h3>Checklist visual (0 a 10)</h3>
+        <div id="checklistGrid" class="checklist-grid"></div>
+
+        <h3>Benchmark rápido de concorrentes</h3>
+        <div id="benchmarkGrid" class="benchmark-grid"></div>
+
+        <div class="charts">
+          <article class="chart-card">
+            <h3>Checklist por categoria (Pizza)</h3>
+            <canvas id="pieChart" width="320" height="320" aria-label="Gráfico de pizza"></canvas>
+          </article>
+          <article class="chart-card">
+            <h3>Benchmark negócio x concorrência (Torres)</h3>
+            <canvas id="barChart" width="480" height="320" aria-label="Gráfico de torres"></canvas>
+          </article>
+        </div>
+
+        <h3>Recomendações para fechamento</h3>
+        <ul id="recommendations"></ul>
+
+        <div class="actions">
+          <button id="downloadReport" type="button">Baixar laudo (HTML)</button>
+        </div>
+      </section>
+
+      <section class="card download">
+        <h2>Download da ferramenta</h2>
+        <a class="download-link" href="download/laudo-gmn-android-pwa.zip" download>Baixar pacote Android (ZIP)</a>
+        <p id="status"></p>
+      </section>
+    </main>
+
+    <script src="app.js"></script>
+  </body>
+</html>
