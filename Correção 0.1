@@ -0,0 +1,39 @@
+# Laudo-GMN
+
+Ferramenta de diagnóstico comercial para prospectar empresas com foco em Google Meu Negócio, tráfego pago e posicionamento digital.
+
+## Fluxo otimizado
+
+1. Preencher dados iniciais:
+   - pesquisa (empresa/empresário + cidade/estado),
+   - segmento,
+   - URL (Google/Instagram/TikTok).
+2. Clicar em **Gerar Laudo Geral**.
+3. Visualizar automaticamente:
+   - checklist visual (0 a 10),
+   - benchmark rápido de concorrentes,
+   - gráfico em pizza,
+   - gráfico em torres,
+   - recomendações comerciais.
+4. Baixar protocolo em HTML para envio ao prospect.
+
+> Importante: checklist e benchmark só aparecem após gerar o laudo.
+
+## Android e download
+
+- Instalação no Android como PWA (botão **Instalar no Android** quando disponível).
+- Pacote ZIP pronto em `download/laudo-gmn-android-pwa.zip`.
+
+Gerar pacote novamente:
+
+```bash
+./scripts/build_download.sh
+```
+
+## Executar localmente
+
+```bash
+python3 -m http.server 8080
+```
+
+Abrir em `http://localhost:8080`.
diff --git a/app.js b/app.js
new file mode 100644
index 0000000000000000000000000000000000000000..fc3efeb9adc49cc15e0a1928491bf69dcf0636d1
--- /dev/null
+++ b/app.js
@@ -0,0 +1,262 @@
+const status = document.getElementById('status');
+const form = document.getElementById('auditForm');
+const resultSection = document.getElementById('resultSection');
+const installBtn = document.getElementById('installBtn');
+
+const summary = document.getElementById('summary');
+const presenceScoreEl = document.getElementById('presenceScore');
+const priorityLevelEl = document.getElementById('priorityLevel');
+const businessRatingEl = document.getElementById('businessRating');
+const topRatingAvgEl = document.getElementById('topRatingAvg');
+const checklistGrid = document.getElementById('checklistGrid');
+const benchmarkGrid = document.getElementById('benchmarkGrid');
+const recommendationsEl = document.getElementById('recommendations');
+const downloadReportBtn = document.getElementById('downloadReport');
+
+const launchDate = '2026-04-03';
+status.textContent = `Build Android preparada em ${launchDate}. Pronta para uso e testes no smartphone.`;
+
+const BASE_CHECKLIST = [
+  { name: 'Perfil completo', score: 6 },
+  { name: 'Categorias corretas', score: 5 },
+  { name: 'Avaliações (nota e volume)', score: 5 },
+  { name: 'Resposta às avaliações', score: 4 },
+  { name: 'Frequência de postagens', score: 4 },
+  { name: 'Qualidade de mídias', score: 6 },
+  { name: 'Perguntas e respostas', score: 4 },
+  { name: 'Conversão (ligar/rota/site)', score: 5 },
+  { name: 'Monitoramento recorrente', score: 3 }
+];
+
+const BASE_BENCHMARK = [
+  { name: 'Avaliação média do negócio (0-5)', value: 4.2 },
+  { name: 'Quantidade de avaliações do negócio', value: 38 },
+  { name: 'Média de avaliações dos TOP 10 concorrentes', value: 92 }
+];
+
+let deferredPrompt;
+let latestReport = null;
+
+const detectPlatform = (url) => {
+  const value = url.toLowerCase();
+  if (value.includes('google.') || value.includes('maps')) return 'Google';
+  if (value.includes('instagram.')) return 'Instagram';
+  if (value.includes('tiktok.')) return 'TikTok';
+  return 'Link geral';
+};
+
+const adjustDataByPlatform = (platform) => {
+  const checklist = BASE_CHECKLIST.map((item) => ({ ...item }));
+  const benchmark = BASE_BENCHMARK.map((item) => ({ ...item }));
+
+  if (platform === 'Google') {
+    checklist.find((item) => item.name === 'Categorias corretas').score += 1;
+    checklist.find((item) => item.name === 'Conversão (ligar/rota/site)').score += 1;
+  }
+
+  if (platform === 'Instagram' || platform === 'TikTok') {
+    checklist.find((item) => item.name === 'Qualidade de mídias').score += 1;
+    checklist.find((item) => item.name === 'Frequência de postagens').score += 1;
+  }
+
+  return { checklist, benchmark };
+};
+
+const drawPieChart = (canvas, checklist) => {
+  const ctx = canvas.getContext('2d');
+  const values = checklist.map((item) => item.score);
+  const total = values.reduce((acc, value) => acc + value, 0);
+  const colors = ['#2563eb', '#38bdf8', '#22c55e', '#f59e0b', '#a855f7', '#ef4444', '#0ea5e9', '#14b8a6', '#eab308'];
+
+  ctx.clearRect(0, 0, canvas.width, canvas.height);
+
+  let start = -Math.PI / 2;
+  values.forEach((value, i) => {
+    const angle = total ? (value / total) * Math.PI * 2 : 0;
+    ctx.beginPath();
+    ctx.moveTo(160, 160);
+    ctx.arc(160, 160, 120, start, start + angle);
+    ctx.closePath();
+    ctx.fillStyle = colors[i % colors.length];
+    ctx.fill();
+    start += angle;
+  });
+};
+
+const drawBarChart = (canvas, benchmark) => {
+  const ctx = canvas.getContext('2d');
+  const labels = ['Negócio', 'Avaliações negócio', 'Média TOP 10'];
+  const values = [benchmark[0].value * 20, benchmark[1].value, benchmark[2].value];
+
+  const max = Math.max(...values, 1);
+  const barWidth = 95;
+  const gap = 28;
+  const baseY = 280;
+
+  ctx.clearRect(0, 0, canvas.width, canvas.height);
+  ctx.fillStyle = '#d1d5db';
+  ctx.fillRect(30, 20, 2, 260);
+  ctx.fillRect(30, 280, 420, 2);
+
+  values.forEach((value, i) => {
+    const height = (value / max) * 220;
+    const x = 55 + i * (barWidth + gap);
+    const y = baseY - height;
+
+    ctx.fillStyle = '#2563eb';
+    ctx.fillRect(x, y, barWidth, height);
+
+    ctx.fillStyle = '#111827';
+    ctx.font = '12px sans-serif';
+    ctx.fillText(labels[i], x, 300);
+    ctx.fillText(String(Math.round(value)), x + 28, y - 8);
+  });
+};
+
+const buildRecommendations = ({ platform, averageScore, benchmark }) => {
+  const rec = [];
+  const reviewGap = benchmark[2].value - benchmark[1].value;
+
+  if (averageScore < 5.5) {
+    rec.push('Prioridade alta: organizar perfil, posts e rotina semanal para subir presença local nos próximos 30 dias.');
+  }
+
+  if (reviewGap > 20) {
+    rec.push('Gap competitivo em avaliações: criar campanha de captação para aproximar do volume médio dos TOP 10.');
+  }
+
+  if (platform === 'Google') {
+    rec.push('Executar plano de Google Meu Negócio com foco em categorias, Q&A e resposta de avaliações em até 24h.');
+  } else {
+    rec.push('Integrar social + Google: transformar conteúdo de rede social em prova social para o Perfil da Empresa.');
+  }
+
+  rec.push('Apresentar proposta com gestão recorrente mensal de GMN + tráfego pago para acelerar geração de leads.');
+  return rec;
+};
+
+const renderChecklist = (checklist) => {
+  checklistGrid.innerHTML = '';
+  checklist.forEach((item) => {
+    const box = document.createElement('article');
+    box.className = 'metric-box';
+    box.innerHTML = `<h4>${item.name}</h4><p>${item.score}/10</p>`;
+    checklistGrid.appendChild(box);
+  });
+};
+
+const renderBenchmark = (benchmark) => {
+  benchmarkGrid.innerHTML = '';
+  benchmark.forEach((item) => {
+    const box = document.createElement('article');
+    box.className = 'metric-box';
+    box.innerHTML = `<h4>${item.name}</h4><p>${item.value}</p>`;
+    benchmarkGrid.appendChild(box);
+  });
+};
+
+form?.addEventListener('submit', (event) => {
+  event.preventDefault();
+
+  const searchBox = document.getElementById('searchBox').value.trim();
+  const segment = document.getElementById('segment').value.trim();
+  const sourceLink = document.getElementById('sourceLink').value.trim();
+
+  const platform = detectPlatform(sourceLink);
+  const { checklist, benchmark } = adjustDataByPlatform(platform);
+
+  const averageScore = Number((checklist.reduce((acc, item) => acc + item.score, 0) / checklist.length).toFixed(1));
+
+  const priorityLevel =
+    averageScore < 5.5 ? 'Alta prioridade (grande oportunidade de fechamento)' :
+    averageScore < 7 ? 'Média prioridade' :
+    'Baixa prioridade';
+
+  summary.textContent = `Empresa pesquisada: ${searchBox} | Segmento: ${segment} | Plataforma: ${platform}.`;
+  presenceScoreEl.textContent = `${averageScore}`;
+  priorityLevelEl.textContent = priorityLevel;
+  businessRatingEl.textContent = `${benchmark[0].value}`;
+  topRatingAvgEl.textContent = `${benchmark[2].value}`;
+
+  renderChecklist(checklist);
+  renderBenchmark(benchmark);
+
+  drawPieChart(document.getElementById('pieChart'), checklist);
+  drawBarChart(document.getElementById('barChart'), benchmark);
+
+  const recommendations = buildRecommendations({ platform, averageScore, benchmark });
+  recommendationsEl.innerHTML = '';
+  recommendations.forEach((item) => {
+    const li = document.createElement('li');
+    li.textContent = item;
+    recommendationsEl.appendChild(li);
+  });
+
+  latestReport = {
+    generatedAt: new Date().toISOString(),
+    searchBox,
+    segment,
+    sourceLink,
+    platform,
+    averageScore,
+    priorityLevel,
+    checklist,
+    benchmark,
+    recommendations
+  };
+
+  resultSection.hidden = false;
+});
+
+downloadReportBtn?.addEventListener('click', () => {
+  if (!latestReport) return;
+
+  const checklistHtml = latestReport.checklist
+    .map((item) => `<li>${item.name}: ${item.score}/10</li>`)
+    .join('');
+  const benchmarkHtml = latestReport.benchmark
+    .map((item) => `<li>${item.name}: ${item.value}</li>`)
+    .join('');
+
+  const html = `<!doctype html><html lang="pt-BR"><head><meta charset="UTF-8"><title>Laudo GMN</title>
+  <style>body{font-family:Arial,sans-serif;padding:20px;color:#1f2937}h1{margin-top:0}.box{border:1px solid #dbe1ee;border-radius:10px;padding:12px;margin:8px 0}</style></head><body>
+  <h1>Protocolo de Laudo - ${latestReport.searchBox}</h1>
+  <div class="box"><strong>Segmento:</strong> ${latestReport.segment}<br><strong>Plataforma:</strong> ${latestReport.platform}<br><strong>Link:</strong> ${latestReport.sourceLink}</div>
+  <div class="box"><strong>Score geral (0-10):</strong> ${latestReport.averageScore}<br><strong>Prioridade:</strong> ${latestReport.priorityLevel}</div>
+  <h2>Checklist visual (0-10)</h2><ul>${checklistHtml}</ul>
+  <h2>Benchmark</h2><ul>${benchmarkHtml}</ul>
+  <h2>Recomendações</h2><ul>${latestReport.recommendations.map((item) => `<li>${item}</li>`).join('')}</ul>
+  <p>Gerado em: ${new Date(latestReport.generatedAt).toLocaleString('pt-BR')}</p></body></html>`;
+
+  const blob = new Blob([html], { type: 'text/html;charset=utf-8' });
+  const url = URL.createObjectURL(blob);
+  const link = document.createElement('a');
+  link.href = url;
+  link.download = `laudo-${latestReport.searchBox.replace(/\s+/g, '-').toLowerCase()}.html`;
+  link.click();
+  URL.revokeObjectURL(url);
+});
+
+window.addEventListener('beforeinstallprompt', (event) => {
+  event.preventDefault();
+  deferredPrompt = event;
+  installBtn.hidden = false;
+});
+
+installBtn?.addEventListener('click', async () => {
+  if (!deferredPrompt) return;
+  deferredPrompt.prompt();
+  await deferredPrompt.userChoice;
+  deferredPrompt = null;
+  installBtn.hidden = true;
+});
+
+if ('serviceWorker' in navigator) {
+  window.addEventListener('load', async () => {
+    try {
+      await navigator.serviceWorker.register('./sw.js');
+    } catch (error) {
+      console.error('Falha ao registrar service worker:', error);
+    }
+  });
+}
