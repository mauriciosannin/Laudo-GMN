@@ -0,0 +1,16 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
+OUT_DIR="$ROOT_DIR/download"
+ZIP_FILE="$OUT_DIR/laudo-gmn-android-pwa.zip"
+
+mkdir -p "$OUT_DIR"
+rm -f "$ZIP_FILE"
+
+cd "$ROOT_DIR"
+zip -r "$ZIP_FILE" \
+  index.html styles.css app.js manifest.webmanifest sw.js offline.html README.md icons \
+  -x "*.DS_Store"
+
+echo "Pacote gerado em: $ZIP_FILE"
