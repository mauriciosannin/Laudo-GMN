+++ b/offline.html
@@ -0,0 +1,19 @@
+<!doctype html>
+<html lang="pt-BR">
+  <head>
+    <meta charset="UTF-8" />
+    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
+    <title>Laudo GMN - Offline</title>
+    <style>
+      body { font-family: system-ui, sans-serif; margin: 0; display: grid; min-height: 100vh; place-items: center; background: #f5f7fb; color: #202736; }
+      .box { background: #fff; border: 1px solid #dbe1ee; border-radius: 14px; padding: 1rem 1.25rem; max-width: 420px; }
+      h1 { margin: 0 0 .5rem; font-size: 1.2rem; }
+    </style>
+  </head>
